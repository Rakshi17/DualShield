<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/card_dark"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SENSOR DEBUG PANEL"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/tvRawAccel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Raw Acceleration (X, Y, Z):\nWaiting for data..."
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvRawTemp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Raw Temperature:\nWaiting for data..."
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvRawGas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Raw Gas (ppm):\nWaiting for data..."
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvRawStructure"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Raw Structure Vibration:\nWaiting for data..."
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Raw JSON Response:"
            android:textColor="@color/primary_blue"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvRawJson"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="{}"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:background="#222222"
            android:padding="8dp" />

    </LinearLayout>
</ScrollView>
