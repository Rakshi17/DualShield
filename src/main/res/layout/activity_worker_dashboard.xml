<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_dashboard_gradient"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- 1. Connection Panel -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvConnectionPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#2A242A33"
            app:cardCornerRadius="16dp"
            app:strokeWidth="1dp"
            app:strokeColor="#55FFFFFF"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical">
                
                <ImageView
                    android:id="@+id/ivWifiIndicator"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_sort_by_size"
                    app:tint="@color/status_safe" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">
                    
                    <TextView
                        android:id="@+id/tvConnectionStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ESP32: Connected"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                        
                    <TextView
                        android:id="@+id/tvIpAddress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="IP: 192.168.4.1 | Signal: -45 dBm"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btnReconnect"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_popup_sync"
                    app:tint="@color/primary_blue" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 2. Safety Status Circular Indicator -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvSafetyStatus"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/status_safe"
            app:cardCornerRadius="110dp"
            app:cardElevation="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cvConnectionPanel">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_gravity="center"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvWorkerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Worker Name"
                    android:textColor="#E6FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="2dp" />
                    
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SYSTEM STATUS"
                    android:textColor="#E6FFFFFF"
                    android:textSize="12sp"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvSafetyStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SAFE"
                    android:textColor="@color/white"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textAlignment="center" />
                    
                <TextView
                    android:id="@+id/tvShiftStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shift: Active"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 3. Live Sensor Panel -->
        <GridLayout
            android:id="@+id/glSensors"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:columnCount="2"
            android:rowCount="2"
            android:useDefaultMargins="true"
            app:layout_constraintTop_toBottomOf="@id/cvSafetyStatus">

            <!-- Body Temp Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvTemp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginStart="0dp"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="12dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Body Temp"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/tvTempStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="36.5°C"
                            android:textColor="@color/status_safe"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvTempTrend"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" →"
                            android:textColor="@color/status_safe"
                            android:textSize="20sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Motion Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvMotion"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="0dp"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Motion"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/tvMotionStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STABLE"
                        android:textColor="@color/status_safe"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Gas Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvGas"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginStart="0dp"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="0dp"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gas Level"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/tvGasStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SAFE"
                            android:textColor="@color/status_safe"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                        <TextView
                            android:id="@+id/tvGasTrend"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" ↓"
                            android:textColor="@color/status_safe"
                            android:textSize="20sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Structure Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cvStructure"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="0dp"
                android:layout_marginBottom="0dp"
                app:cardBackgroundColor="@color/card_dark"
                app:cardCornerRadius="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Structural Stability"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/tvStructureStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STABLE"
                        android:textColor="@color/status_safe"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </GridLayout>

        <!-- 4. AI Insight Panel -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvAiInsight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#1A2196F3"
            app:cardCornerRadius="12dp"
            app:strokeWidth="1dp"
            app:strokeColor="#4D2196F3"
            app:layout_constraintTop_toBottomOf="@id/glSensors">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:orientation="vertical">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🧠 AI PREDICITVE INSIGHT"
                        android:textColor="@color/primary_blue"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                    
                    <TextView
                        android:id="@+id/tvAiConfidence"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="92% Confidence"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvAiExplanation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="All parameters normal. Expected to remain SAFE for the next 120 seconds."
                    android:textColor="@color/white"
                    android:textSize="14sp" />
                    
                <TextView
                    android:id="@+id/tvAiTimer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Next model update: 00:05"
                    android:textColor="@color/primary_blue"
                    android:textSize="12sp"
                    android:textStyle="italic" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 5. Real-Time History Log -->
        <TextView
            android:id="@+id/tvHistoryTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="REAL-TIME LOG"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cvAiInsight" />

        <ScrollView
            android:id="@+id/svHistory"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/card_bg"
            android:padding="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvHistoryTitle">
            
            <TextView
                android:id="@+id/tvHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No events yet."
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="monospace" />
        </ScrollView>
        
        <!-- 7. Device Status -->
        <LinearLayout
            android:id="@+id/llDeviceStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/svHistory">
            
            <TextView
                android:id="@+id/tvBattery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔋 85%"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginEnd="16dp" />
                
            <TextView
                android:id="@+id/tvLatency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡ 14ms"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginEnd="16dp" />
                
            <TextView
                android:id="@+id/tvFirmware"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v1.2.4"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Manual Shift Button -->
        <Button
            android:id="@+id/btnToggleShift"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="16dp"
            android:text="MARK ATTENDANCE (START SHIFT)"
            android:backgroundTint="#4CAF50"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:layout_constraintTop_toBottomOf="@id/llDeviceStatus" />

        <!-- 6. Emergency Button -->
        <Button
            android:id="@+id/btnEmergency"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:text="EMERGENCY HELP"
            android:backgroundTint="@color/status_danger"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:layout_constraintTop_toBottomOf="@id/btnToggleShift" />

        <!-- 8. Sensor Debug Panel -->
        <Button
            android:id="@+id/btnSensorDebug"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"
            android:text="SENSOR DEBUG PANEL"
            android:backgroundTint="#00838F"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/btnEmergency" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>